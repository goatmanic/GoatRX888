diff --git a/SDDC_FX3/driver/tuner_r82xx.c b/SDDC_FX3/driver/tuner_r82xx.c
index 0f9544c..751fe22 100644
--- a/SDDC_FX3/driver/tuner_r82xx.c
+++ b/SDDC_FX3/driver/tuner_r82xx.c
@@ -2413,4 +2413,31 @@ int set_all_gains(struct r82xx_priv *priv, UINT8 gain_index)
 
 	return 0;
 }
+
+/* Enable/disable R8xx LNA+mixer hardware AGC.
+ * Uses masked writes so AIR_CABLE1_IN / LOOP_THROUGH (R5) and
+ * IMG_R / mixer power+current (R7) are preserved, and the firmware
+ * register shadow stays in sync. on==0 restores the last manual gain. */
+int set_agc(struct r82xx_priv *priv, UINT8 on)
+{
+	int rc;
+
+	if (on) {
+		/* LNA auto on == AGC */
+		rc = r82xx_write_reg_mask(priv, 0x05, 0x00, 0x10);
+		if (rc < 0)
+			return rc;
+
+		/* Mixer auto on == AGC */
+		rc = r82xx_write_reg_mask(priv, 0x07, 0x10, 0x10);
+		if (rc < 0)
+			return rc;
+
+		DebugPrint(4, "\r\nset_agc ON");
+		return 0;
+	}
+
+	DebugPrint(4, "\r\nset_agc OFF -> restore manual %d", m_gain_index);
+	return set_all_gains(priv, m_gain_index);
+}
 #endif
